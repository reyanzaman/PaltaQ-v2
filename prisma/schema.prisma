generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String        @id @default(uuid())
  email             String        @unique
  name              String?
  image             String        @default("/default_image2.png")
  is_Admin          Boolean       @default(false)
  is_Faculty        Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  questions         Question[]    @relation("UserQuestions")
  userDetails       UserDetails?  // One-to-one relationship
  reports           Reports[]     // One-to-many relationship with Reports
  likedQuestions    Likes[]       @relation("UserLikes")
  dislikedQuestions Dislikes[]    @relation("UserDislikes")
  paltaQuestions    PaltaQ[]      @relation("UserPaltaQ")
  classes           ClassEnrollment[] // Many-to-many relationship with Classes
  taughtClasses  ClassFaculty[]    // Many-to-many relationship with Classes for faculty members
  preQuestionnaire  PreQuestionnaire[] // One-to-many relationship
  postQuestionnaire PostQuestionnaire[] // One-to-many relationship
}

model UserDetails {
  userId           String   @id
  totalScore       Int      @default(0)
  questionsAsked   Int      @default(0)
  paltaQAsked      Int      @default(0)
  successfulReports Int     @default(0)

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Classes {
  id              String          @id @default(uuid())
  name            String          @unique
  code            String          @unique
  creatorId       String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  endsAt          DateTime?
  questionnaire   Boolean        @default(false)

  faculties   ClassFaculty[]  // Many-to-many relationship with Users for faculty members
  enrollments ClassEnrollment[] // Many-to-many relationship with Users
  topics      Topic[]         // One-to-many relationship with Topics
  questions   Question[]      // One-to-many relationship with Questions
}

model ClassFaculty {
  id          String   @id @default(uuid())
  classId     String
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  class       Classes  @relation(fields: [classId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classId, userId])
}

model ClassEnrollment {
  id            String    @id @default(uuid())
  userId        String
  classId       String
  score         Int       @default(0)
  rank          String    @default("Novice Inquirer")
  questionCount Int       @default(0)
  paltaQCount   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  class      Classes  @relation(fields: [classId], references: [id], onDelete: Cascade)
  preQuestionnaire  PreQuestionnaire? // One-to-one relationship
  postQuestionnaire PostQuestionnaire? // One-to-one relationship

  @@unique([userId, classId])
}

model Topic {
  id        String      @id @default(uuid())
  name      String
  classId   String
  questions Question[] // One-to-many relationship with Questions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())

  class     Classes     @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([name, classId]) // Unique constraint to ensure no duplicate topics within the same class
}

enum QuestionCategory {
  General
  Topic
  Palta
  PaltaPalta
}

model Question {
  id            String       @id @default(uuid())
  userId        String
  question      String
  score         Int          @default(0)
  likes         Int          @default(0)
  dislikes      Int          @default(0)
  paltaQ        Int          @default(0)

  llama_score   Int          @default(0)
  quban_score   Int          @default(0)

  category      QuestionCategory // Enum type for category
  isAnonymous   Boolean      @default(false)
  isArchived    Boolean      @default(false)
  
  topicId       String       // Foreign key to Topic
  classId       String       // Foreign key to Classes

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user          User         @relation(fields: [userId], references: [id], name: "UserQuestions")
  topic         Topic        @relation(fields: [topicId], references: [id])
  questionType  QuestionType[] // One-to-many relationship with QuestionType
  reports       Reports[]    // One-to-many relationship with Reports
  likedBy       Likes[]      @relation("QuestionLikes")
  dislikedBy    Dislikes[]   @relation("QuestionDislikes")
  paltaQBy      PaltaQ[]     @relation("QuestionPaltaQ")
  subPaltaQ     PaltaQ[]     @relation("ParentQuestion")
  class         Classes      @relation(fields: [classId], references: [id], onDelete: Cascade)
}

model QuestionType {
  id            String   @id @default(uuid())
  questionId    String?
  paltaQId      String?
  remembering   Boolean  @default(false)
  understanding Boolean  @default(false)
  applying      Boolean  @default(false)
  analyzing     Boolean  @default(false)
  evaluating    Boolean  @default(false)
  creating      Boolean  @default(false)

  question      Question? @relation(fields: [questionId], references: [id], onDelete: Cascade)
  paltaQ        PaltaQ? @relation(fields: [paltaQId], references: [id], onDelete: Cascade)
}

model Reports {
  id          String   @id @default(uuid())
  userId      String
  questionId  String
  paltaQId    String
  reportSuccess Boolean @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  paltaQ      PaltaQ   @relation(fields: [paltaQId], references: [id], onDelete: Cascade)
}

model Likes {
  id          String   @id @default(uuid())
  userId      String
  questionId  String?
  paltaQId    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user        User     @relation(fields: [userId], references: [id], name: "UserLikes")
  question    Question? @relation(fields: [questionId], references: [id], name: "QuestionLikes", onDelete: Cascade)
  paltaQ      PaltaQ?   @relation(fields: [paltaQId], references: [id], name: "LikedPaltaQ", onDelete: Cascade)
}

model Dislikes {
  id          String   @id @default(uuid())
  userId      String
  questionId  String?
  paltaQId    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user        User     @relation(fields: [userId], references: [id], name: "UserDislikes")
  question    Question? @relation(fields: [questionId], references: [id], name: "QuestionDislikes", onDelete: Cascade)
  paltaQ      PaltaQ?   @relation(fields: [paltaQId], references: [id], name: "DislikedPaltaQ", onDelete: Cascade)
}

model PaltaQ {
  id            String   @id @default(uuid())
  userId        String
  questionId    String?     // Foreign key to Question
  parentId      String?     // Foreign key to PaltaQ
  mainQuestionID String?    // Foreign key to Question
  paltaQ        String
  score         Int          @default(0)
  likes         Int          @default(0)
  dislikes      Int          @default(0)

  llama_score   Int          @default(0)
  quban_score   Int          @default(0)

  isAnonymous   Boolean      @default(false)
  isArchived    Boolean      @default(false)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  likedBy       Likes[]    @relation("LikedPaltaQ")
  dislikedBy    Dislikes[] @relation("DislikedPaltaQ")
  reports       Reports[]    // One-to-many relationship with Reports
  questionType  QuestionType[] // One-to-many relationship with QuestionType

  user        User     @relation(fields: [userId], references: [id], name: "UserPaltaQ")
  question    Question? @relation(fields: [questionId], references: [id], name: "QuestionPaltaQ", onDelete: Cascade)
  parentMQ    Question? @relation("ParentQuestion", fields: [mainQuestionID], references: [id])
  parent      PaltaQ?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies     PaltaQ[] @relation("CommentReplies")

  @@index([parentId])
}

model PreQuestionnaire {
  id                      Int      @id @default(autoincrement())
  isCompleted             Boolean  @default(false)
  userId                  String   
  classId                 String   @unique
  studentId               String   @default("")

  // Demographics
  age                     String   @default("")
  gender                  String   @default("")
  schoolLocation          String   @default("")
  maritalStatus           String   @default("")
  // Academic
  studyMotivation         String   @default("")
  studyCuriosity          String   @default("")
  quesionsAsked           String   @default("")
  questionExample         String   @default("")
  subjectILike            String   @default("")
  dontEnjoyStudying       String   @default("")
  cgpa                    String   @default("")
  extraCurricular         String   @default("")
  studyTime               String   @default("")
  leisureTime             String   @default("")
  // Curiosity
  questionArises          String @default("")
  courageToAsk            String @default("")
  curiousToKnow           String @default("")
  whyChildrenAskQuestions String @default("")
  // Motivation
  desireToLearn           String @default("")
  askTeacher              String @default("")
  askPeer                 String @default("")
  askMyself               String @default("")
  askGPT                  String @default("")
  askResearch             String @default("")
  askAvoid                String @default("")
  motivatedToAsk          String @default("")
  // Engagement
  multQuesAskStudents     String @default("")
  multQuesAskGroup        String @default("")
  multQuesAskMyself       String @default("")
  multQuesAvoid           String @default("")
  multQuesResearch        String @default("")
  multQuesMemorize        String @default("")
  // Confidence
  quesHelpsUnderstand     String @default("")
  easierToMemorize        String @default("")
  opinionAskingQues       String @default("")
  opinionMemorizing       String @default("")
  opinionPracticing       String @default("")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
  class             ClassEnrollment  @relation(fields: [classId], references: [id], onDelete: Cascade)
}

model PostQuestionnaire {
  id                      Int      @id @default(autoincrement())
  isCompleted             Boolean  @default(false)
  userId                  String   
  classId                 String   @unique
  studentId               String   @default("")
  
  // Opinion about PaltaQ
  interestPaltaQ          String @default("")
  suggestionsPaltaQ       String @default("")
  // Academic
  studyMotivation         String @default("")
  studyCuriosity          String @default("")
  quesionsAsked           String @default("")
  questionExample         String @default("")
  subjectILike            String @default("")
  dontEnjoyStudying       String @default("")
  cgpa                    String @default("")
  extraCurricular         String @default("")
  studyTime               String @default("")
  leisureTime             String @default("")
  // Curiosity
  questionArises          String @default("")
  courageToAsk            String @default("")
  curiousToKnow           String @default("")
  whyChildrenAskQuestions String @default("")
  // Motivation
  desireToLearn           String @default("")
  askTeacher              String @default("")
  askPeer                 String @default("")
  askMyself               String @default("")
  askGPT                  String @default("")
  askResearch             String @default("")
  askAvoid                String @default("")
  motivatedToAsk          String @default("")
  // Engagement
  multQuesAskStudents     String @default("")
  multQuesAskGroup        String @default("")
  multQuesAskMyself       String @default("")
  multQuesAvoid           String @default("")
  multQuesResearch        String @default("")
  multQuesMemorize        String @default("")
  // Confidence
  quesHelpsUnderstand     String @default("")
  easierToMemorize        String @default("")
  opinionAskingQues       String @default("")
  opinionMemorizing       String @default("")
  opinionPracticing       String @default("")

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
  class             ClassEnrollment  @relation(fields: [classId], references: [id], onDelete: Cascade)
}